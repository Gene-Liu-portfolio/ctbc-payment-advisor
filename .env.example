# ── Anthropic Claude API ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here   # 至 https://console.anthropic.com 取得

# ── Claude 模型設定 ───────────────────────────────────────────────────────────
CLAUDE_AGENT_MODEL=claude-sonnet-4-6                  # 多輪對話 Agent（tool calling）
CLAUDE_PARSER_MODEL=claude-haiku-4-5-20251001         # 自然語言解析消費情境
CLAUDE_REASONER_MODEL=claude-haiku-4-5-20251001       # 為推薦結果產生中文理由

# ── Scraper 設定 ──────────────────────────────────────────────────────────────
SCRAPER_HEADLESS=true        # true = no browser window; false = visible browser (debug用)
SCRAPER_DELAY_MIN=1.0        # 每次請求前最小延遲秒數
SCRAPER_DELAY_MAX=3.0        # 每次請求前最大延遲秒數
SCRAPER_TIMEOUT=30000        # 頁面等待 timeout (ms)
